{
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "regions": ["syd1"],
  "crons": [
    {"path": "/cron/send", "schedule": "*/5 * * * *"},
    {"path": "/cron/sync-inbox", "schedule": "*/5 * * * *"},
    {"path": "/cron/campaign", "schedule": "*/5 * * * *"}
  ]
}